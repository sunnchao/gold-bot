# Gold-Bot 环境变量配置
# 复制此文件为 .env 并填入真实值
# NEVER commit .env to git!

# ========== 服务端配置 ==========
GBOLT_HOST=0.0.0.0
GBOLT_PORT=8880
GBOLT_DEBUG=0

# ========== 安全配置 ==========
# 管理员 Token（可查看所有账户）- 必填
ADMIN_TOKEN=
# Flask Session Secret Key（留空则自动生成随机值）
FLASK_SECRET_KEY=

# ========== 飞书推送 ==========
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# ========== Discord 推送 ==========
DISCORD_WEBHOOK_URL=

# ========== Agent 脚本配置 ==========
# 用于 Agent 上报结果的 API Token
GBOLT_API_TOKEN=